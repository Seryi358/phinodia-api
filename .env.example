# KIE AI — Video (VEO 3.1) + Image (Nano Banana 2) generation
KIE_API_KEY=your_kie_api_key_here
KIE_BASE_URL=https://api.kie.ai/api/v1

# OpenAI — GPT-4o for script/prompt generation
OPENAI_API_KEY=your_openai_api_key_here

# Wompi (Colombian payment gateway) — https://comercios.wompi.co
WOMPI_PRIVATE_KEY=your_wompi_private_key_here
WOMPI_PUBLIC_KEY=your_wompi_public_key_here
WOMPI_EVENTS_SECRET=your_wompi_events_secret_here
WOMPI_INTEGRITY_SECRET=your_wompi_integrity_secret_here
WOMPI_ENVIRONMENT=production

# Gmail OAuth2 — for delivery emails
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here
GMAIL_SENDER_EMAIL=scastellanos@phinodia.com

# App
DATABASE_URL=sqlite+aiosqlite:///./data/phinodia.db
CORS_ORIGINS=["https://phinodia.com","https://www.phinodia.com","https://app.phinodia.com"]
API_BASE_URL=https://app.phinodia.com
